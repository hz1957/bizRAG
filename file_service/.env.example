FILE_SERVICE_HOST=0.0.0.0
FILE_SERVICE_PORT=8002
FILE_SERVICE_STORAGE_ROOT=runtime/file_service/storage
FILE_SERVICE_DATABASE=runtime/file_service/state/metadata.db
FILE_SERVICE_SOURCE_URI_PREFIX=filestore
FILE_SERVICE_BASE_URL=http://127.0.0.1:8002
# 事件中的 download_url 使用该地址。若 BizRAG 在 Docker 中运行，请换成宿主机可访问地址
# 如 http://host.docker.internal:8002 (macOS) 或宿主机局域网 IP（如 http://172.17.0.1:8002）
FILE_SERVICE_DOWNLOAD_BASE_URL=http://127.0.0.1:8002

# MQ 发布方式：rabbitmq（默认）/ http（开发联调用）
FILE_SERVICE_PUBLISHER_BACKEND=rabbitmq
FILE_SERVICE_RABBITMQ_URL=amqp://guest:guest@127.0.0.1//
FILE_SERVICE_RABBITMQ_QUEUE=bizrag.rustfs.events

# 如果改用 http 桥接到 BizRAG 的 /api/v1/events/rustfs/queue/batch
FILE_SERVICE_HTTP_BRIDGE_URL=http://127.0.0.1:64501

FILE_SERVICE_POLL_INTERVAL=2
FILE_SERVICE_BATCH_SIZE=50
FILE_SERVICE_MAX_RETRY=12
FILE_SERVICE_HTTP_TIMEOUT=5
FILE_SERVICE_CORS=http://127.0.0.1:3000,http://127.0.0.1:64501
FILE_SERVICE_WATCH_ENABLED=false
FILE_SERVICE_WATCH_ROOT=runtime/file_service/watch
FILE_SERVICE_WATCH_DEFAULT_KB_ID=default
FILE_SERVICE_WATCH_TENANT_ID=default
FILE_SERVICE_WATCH_RECURSIVE=true
FILE_SERVICE_WATCH_INITIAL_SCAN=true
FILE_SERVICE_WATCH_DEBOUNCE_SECONDS=1.0
FILE_SERVICE_WATCH_DELETE_SYNC=true
FILE_SERVICE_WATCH_RECONCILE_INTERVAL_SECONDS=5.0
FILE_SERVICE_WATCH_AUTO_REGISTER_ENABLED=false
# BizRAG register-kb endpoint。Docker 内通常是 http://bizrag:64501/api/v1/admin/kbs/register
FILE_SERVICE_WATCH_AUTO_REGISTER_URL=http://127.0.0.1:64501/api/v1/admin/kbs/register
# 注意：这个路径是从 BizRAG 进程视角看的 source_parameters_path，不是 file_service 容器内的路径
FILE_SERVICE_WATCH_AUTO_REGISTER_SOURCE_PARAMETERS_PATH=/absolute/path/to/bizrag/servers/retriever/parameter.yaml
FILE_SERVICE_WATCH_AUTO_REGISTER_SOURCE_ROOT_PREFIX=
FILE_SERVICE_WATCH_AUTO_REGISTER_TIMEOUT_SECONDS=30.0
