MYSQL_DATABASE=bizrag
MYSQL_USER=bizrag
MYSQL_PASSWORD=bizrag
MYSQL_ROOT_PASSWORD=root
MYSQL_PORT=3306
# BizRAG metadata DSN is composed from the MySQL variables above inside docker-compose.yml.
# Example explicit DSN:
# mysql+pymysql://bizrag:bizrag@mysql:3306/bizrag

RABBITMQ_DEFAULT_USER=guest
RABBITMQ_DEFAULT_PASS=guest
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
RUSTFS_RABBITMQ_QUEUE=bizrag.rustfs.events

MILVUS_PORT=19530
MILVUS_HEALTH_PORT=9091
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

BIZRAG_PORT=64501
BIZRAG_RUSTFS_TOKEN=
BIZRAG_RUSTFS_SHARED_SECRET=
BIZRAG_ACCELERATOR=cpu
BIZRAG_GPU_IDS=
BIZRAG_HOT_RELOAD=false
BIZRAG_HF_OFFLINE=false
BIZRAG_READ_WARMUP=true
BIZRAG_READ_WARMUP_MODE=all
BIZRAG_READ_WARMUP_KB_IDS=
BIZRAG_BOOTSTRAP_RUNTIME=true
BIZRAG_BOOTSTRAP_MODELS=true
BIZRAG_BOOTSTRAP_MINERU=true
BIZRAG_BOOTSTRAP_MINERU_MODEL_TYPE=pipeline
BIZRAG_RABBITMQ_PREFETCH=20
BIZRAG_WORKER_POLL_INTERVAL=2.0
BIZRAG_WORKER_BATCH_SIZE=10
BIZRAG_WORKER_LEASE_SECONDS=45.0
BIZRAG_WORKER_HEARTBEAT_INTERVAL=15.0
BIZRAG_WORKER_MAX_ATTEMPTS=3
BIZRAG_TASK_TIMEOUT_SECONDS=120.0
BIZRAG_TASK_HEARTBEAT_INTERVAL_SECONDS=5.0
BIZRAG_MAX_EVENTS_PER_MESSAGE=100
BIZRAG_WAIT_TIMEOUT=90
HF_CACHE_DIR=./runtime/hf_cache
MINERU_MODEL_SOURCE=modelscope

# OpenAI-compatible generation backend used by /api/v1/rag and related pipelines.
LLM_MODEL_NAME=deepseek-chat
LLM_API_URL_AGENT=https://ai-cloud.r2ai.com.cn/v1
LLM_API_KEY_AGENT=sk-trF80Nkvw0cED20JoZPuJGfwcsfiSfoOXre3DKetKaIL0WAG

# file_service watch / auto-register settings used by docker-compose.yml.
FILE_SERVICE_WATCH_DEFAULT_KB_ID=contracts_compose_auto
FILE_SERVICE_WATCH_RECONCILE_INTERVAL_SECONDS=5.0
FILE_SERVICE_WATCH_AUTO_REGISTER_URL=http://bizrag:64501/api/v1/admin/kbs/register
FILE_SERVICE_WATCH_AUTO_REGISTER_SOURCE_PARAMETERS_PATH=/app/bizrag/servers/retriever/parameter.docker.yaml
FILE_SERVICE_WATCH_AUTO_REGISTER_SOURCE_ROOT_PREFIX=/app/runtime/file_service/watch
FILE_SERVICE_WATCH_AUTO_REGISTER_TIMEOUT_SECONDS=30.0

# Replace with your actual RustFS image when available.
RUSTFS_IMAGE=ghcr.io/rustfs/rustfs:latest
RUSTFS_PORT=9000

# Optional Hugging Face token. Keep blank unless you need gated/private models or datasets.
HF_TOKEN=
